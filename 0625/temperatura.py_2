def farenheit_para_celcius(f):
         """converte a temperatura de farenheit para celcius"""
         celcius = (f-32) * 5 / 9
         return celcius
temperatura = int(input("digite a temperatura em graus farenheit: "))
farenheit = temperatura
celcius = (temperatura-32) * 5 / 9
print(f"a temperatura de {temperatura: .1f}°f fica em graus celcius: {celcius: .1f}")